# HuggingFace token — required for gated models when downloading from HuggingFace.
# Not needed when running in offline mode (MODEL_DIR is set).
HF_TOKEN=hf_your_token_here

# Root directory containing locally cloned HuggingFace model repos.
# When set, the server runs fully offline using the local checkpoint instead of
# downloading from HuggingFace. Leave unset to download normally.
#
# The model is looked up at: $MODEL_DIR/$HF_MODEL_ID
# For example, if MODEL_DIR=/data/models and the compose file targets
# Qwen/Qwen3.5-35B-A3B, the model must exist at:
#   /data/models/Qwen/Qwen3.5-35B-A3B
#
# Download a model using the HuggingFace CLI (no git required, skips repo history):
#   hf download Qwen/Qwen3.5-35B-A3B --local-dir /data/models/Qwen/Qwen3.5-35B-A3B
#
# Or clone the full git repo with git-lfs (preserves revision history):
#   git lfs install
#   git clone https://huggingface.co/Qwen/Qwen3.5-35B-A3B /data/models/Qwen/Qwen3.5-35B-A3B
#
# Prefer huggingface cli for large models — it downloads only the model files,
# supports resuming interrupted downloads, and skips git history overhead.
#
# MODEL_DIR=/data/models
